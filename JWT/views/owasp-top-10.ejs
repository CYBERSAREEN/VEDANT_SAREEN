                  <button class="code-block__copy">Copy</button>
                </div>
                <pre><code>// Vulnerable: using node-serialize with user input
const serialize = require('node-serialize');

app.post('/api/profile', (req, res) => {
  const userData = serialize.unserialize(req.cookies.profile);
  // 💀 Attacker sets cookie to:
  // {"username":"_$$ND_FUNC$$_function(){require('child_process').exec('rm -rf /')}()"}
  // → Remote Code Execution!
});

// CDN without SRI:
// &lt;script src="https://cdn.example.com/lib.js"&gt;&lt;/script&gt;
// If CDN is compromised, malicious code runs on all sites using it

// ✅ SECURE with SRI:
// &lt;script src="https://cdn.example.com/lib.js"
//   integrity="sha384-oqVuAfXRKap7fdgcCY5uykM6+R9GqQ8K/uxy9rx7HNQlGYl1kPzQho1wx4JwY8wC"
//   crossorigin="anonymous"&gt;&lt;/script&gt;</code></pre>
              </div>
            </div>
          </div>

          <div class="info-box info-box--remediation">
            <div class="info-box__title">✅ D. Remediation</div>
            <div class="info-box__content">
              <ul>
                <li>Use <strong>digital signatures</strong> to verify software/data integrity</li>
                <li>Implement <strong>Subresource Integrity (SRI)</strong> for all CDN resources</li>
                <li>Run <code>npm audit</code> and <code>snyk test</code> in CI/CD pipeline</li>
                <li>Use <strong>lockfiles</strong> (<code>package-lock.json</code>) to pin dependency versions</li>
                <li>Ensure CI/CD has proper <strong>access controls</strong> and audit logging</li>
                <li>Never deserialize untrusted data — use safe alternatives (JSON.parse)</li>
                <li>Code review all changes to build and deployment configurations</li>
              </ul>
            </div>
          </div>
