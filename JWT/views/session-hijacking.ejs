      <pre><code>const express = require('express');
const session = require('express-session');
const app = express();

app.use(session({
  secret: 'weak-secret',
  resave: false,
  saveUninitialized: true,  // ❌ Creates session BEFORE login
  // genid not implemented — accepts URL-provided session IDs! ❌
}));

app.use(express.urlencoded({ extended: true }));

// ❌ VULNERABLE: Accepts session ID from URL query
app.use((req, res, next) => {
  if (req.query.SESSIONID) {
    req.sessionID = req.query.SESSIONID;  // ❌ Session fixation!
  }
  next();
});

app.get('/login', (req, res) => {
  res.send('&lt;form method="POST" action="/login"&gt;&lt;input name="user"&gt;&lt;input name="pass" type="password"&gt;&lt;button&gt;Login&lt;/button&gt;&lt;/form&gt;');
});

app.post('/login', (req, res) => {
  // ❌ DOES NOT regenerate session ID after login!
  req.session.user = req.body.user;
  req.session.authenticated = true;
  res.redirect('/dashboard');
});

app.get('/dashboard', (req, res) => {
  if (!req.session.authenticated) return res.redirect('/login');
  res.send('Welcome, ' + req.session.user + '! Session ID: ' + req.sessionID);
});</code></pre>
