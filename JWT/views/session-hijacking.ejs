  <!-- Remediation -->
  <div class="section">
    <div class="section__header">
      <div class="section__number">Section 4.5</div>
      <h2 class="section__title">Complete Remediation Guide</h2>
    </div>

    <div class="info-box info-box--remediation">
      <div class="info-box__title">✅ Session Security Checklist</div>
      <div class="info-box__content">
        <ul>
          <li>✅ <strong>Regenerate session ID</strong> after login (invalidate old session)</li>
          <li>✅ Use <strong>cryptographically strong random</strong> session IDs (128-bit minimum)</li>
          <li>✅ Set <strong>HttpOnly, Secure, SameSite</strong> on session cookies</li>
          <li>✅ Implement <strong>session timeouts</strong>: idle (15-30 min) + absolute (8-24 hours)</li>
          <li>✅ <strong>Destroy sessions</strong> on logout (server-side)</li>
          <li>✅ <strong>Bind sessions</strong> to client fingerprint (IP hash + User-Agent)</li>
          <li>✅ Use <strong>HTTPS everywhere</strong> to prevent sidejacking</li>
          <li>✅ Implement <strong>concurrent session detection</strong> (alert on new device)</li>
          <li>✅ <strong>Never accept session IDs</strong> from URL parameters or POST data</li>
          <li>✅ Store session data in secure backends (Redis with TLS, not in-memory)</li>
        </ul>
      </div>
    </div>

    <div class="code-block">
      <div class="code-block__header">
        <span class="code-block__lang">JavaScript — Secure Session Implementation</span>
        <button class="code-block__copy">Copy</button>
      </div>
      <pre><code>const crypto = require('crypto');
const session = require('express-session');
const RedisStore = require('connect-redis').default;
const redis = require('redis');

const redisClient = redis.createClient({ url: process.env.REDIS_URL });

app.use(session({
  store: new RedisStore({ client: redisClient }),
  secret: crypto.randomBytes(32).toString('hex'),
  resave: false,
  saveUninitialized: false, // ✅ Don't create until login
  name: '__Host-sid',       // ✅ Cookie prefix for extra security
  cookie: {
    httpOnly: true,         // ✅ No JS access
    secure: true,           // ✅ HTTPS only
    sameSite: 'strict',     // ✅ No cross-site
    maxAge: 1800000         // ✅ 30 min idle timeout
  }
}));

// ✅ CRITICAL: Regenerate session ID after login
app.post('/login', async (req, res) => {
  const user = await validateCredentials(req.body);
  if (!user) return res.status(401).json({ error: 'Invalid credentials' });

  // Destroy old session and create new one
  req.session.regenerate((err) => {
    if (err) return res.status(500).end();
    req.session.userId = user.id;
    req.session.role = user.role;
    req.session.loginTime = Date.now();
    req.session.clientIP = req.ip;                    // ✅ Bind to IP
    req.session.userAgent = req.headers['user-agent']; // ✅ Bind to UA
    res.redirect('/dashboard');
  });
});

// ✅ Validate session binding on every request
app.use((req, res, next) => {
  if (req.session.userId) {
    if (req.session.clientIP !== req.ip ||
        req.session.userAgent !== req.headers['user-agent']) {
      req.session.destroy();
      return res.status(401).json({ error: 'Session invalidated — fingerprint mismatch' });
    }
  }
  next();
});</code></pre>
