  <!-- What is a Session? -->
  <div class="section">
    <div class="section__header">
      <div class="section__number">Section 4.1</div>
      <h2 class="section__title">What is a Session?</h2>
    </div>
    <div class="section__content">
      <p>A <strong>session</strong> is a semi-permanent interactive information interchange between a client and a server. Since HTTP is a stateless protocol (each request is independent), sessions were invented to maintain state across multiple requests. After a user authenticates, the server creates a unique session identifier that is used to track the user's activity.</p>
    </div>

    <div class="info-box info-box--explain">
      <div class="info-box__title">ℹ️ Session Types</div>
      <div class="info-box__content">
        <ul>
          <li><strong>Server-Side Sessions:</strong> Session data stored on the server (in memory, Redis, DB). Client only holds a session ID in a cookie. Traditional approach.</li>
          <li><strong>Client-Side Sessions (JWT):</strong> All session data stored in the token itself. Server is stateless. Modern approach used in SPAs and microservices.</li>
          <li><strong>Hybrid:</strong> JWT access token for short-lived auth + server-side refresh tokens for session management.</li>
        </ul>
      </div>
    </div>

    <div class="code-block">
      <div class="code-block__header">
        <span class="code-block__lang">JavaScript — Session Flow</span>
        <button class="code-block__copy">Copy</button>
      </div>
      <pre><code>// Server-Side Session Example
const session = require('express-session');

app.use(session({
  secret: 'super-secret-key',
  resave: false,
  saveUninitialized: false,
  cookie: { secure: true, httpOnly: true, maxAge: 1800000 }
}));

// Login: Create session
app.post('/login', (req, res) => {
  // After validating credentials...
  req.session.userId = user.id;        // Store user info in session
  req.session.role = user.role;
  req.session.loginTime = Date.now();
  // → Server generates session ID → stores in cookie: connect.sid=s%3A...
  res.redirect('/dashboard');
});

// Protected route: Read session
app.get('/dashboard', (req, res) => {
  if (!req.session.userId) return res.redirect('/login');
  // Session is valid — user is authenticated
});</code></pre>
    </div>
  </div>

  <!-- Types of Session Attacks -->
  <div class="section">
    <div class="section__header">
