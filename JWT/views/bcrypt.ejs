      </div>
      <pre><code>const bcrypt = require('bcryptjs');
const SALT_ROUNDS = 12;  // Recommended default

// ─── Registration: Hash the password ───────────────────
app.post('/register', async (req, res) => {
  const { email, password } = req.body;

  // Validate password strength
  if (password.length < 12) {
    return res.status(400).json({ error: 'Password must be at least 12 characters' });
  }

  // Hash the password (bcrypt automatically generates salt)
  const hashedPassword = await bcrypt.hash(password, SALT_ROUNDS);

  // Store in database (NEVER store plaintext!)
  await db.query(
    'INSERT INTO users (email, password_hash) VALUES ($1, $2)',
    [email, hashedPassword]
  );

  // hashedPassword looks like:
  // $2b$12$LJ3m4ys3Lf0Xg9YGlNkPSOiVcKF/T7vLI2eMyPjjz7YNq.Jz8qDPi

  res.json({ message: 'User registered successfully' });
});

// ─── Login: Compare password with hash ─────────────────
app.post('/login', async (req, res) => {
  const { email, password } = req.body;

  // Fetch user from database
  const user = await db.query('SELECT * FROM users WHERE email = $1', [email]);
  if (!user) {
    // ✅ Don't reveal whether email exists!
    return res.status(401).json({ error: 'Invalid credentials' });
  }

  // Compare provided password with stored hash
  // bcrypt.compare extracts the salt from the hash and applies it
  const isValid = await bcrypt.compare(password, user.password_hash);

  if (!isValid) {
    return res.status(401).json({ error: 'Invalid credentials' });
  }

  // Password is correct! Create session/JWT
  const token = jwt.sign({ sub: user.id, role: user.role }, SECRET, { expiresIn: '15m' });
  res.json({ token });
});

// ─── Password Change: Re-hash with new cost factor ─────
app.post('/change-password', authenticate, async (req, res) => {
  const { currentPassword, newPassword } = req.body;
  const user = await db.query('SELECT * FROM users WHERE id = $1', [req.user.sub]);

  // Verify current password
  const isValid = await bcrypt.compare(currentPassword, user.password_hash);
  if (!isValid) return res.status(401).json({ error: 'Current password incorrect' });

  // Hash new password (possibly with higher cost factor)
  const newHash = await bcrypt.hash(newPassword, SALT_ROUNDS);
  await db.query('UPDATE users SET password_hash = $1 WHERE id = $2', [newHash, user.id]);

  res.json({ message: 'Password changed successfully' });
});</code></pre>
