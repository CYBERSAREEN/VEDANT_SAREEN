        <span class="code-block__lang">JavaScript — Vulnerable App (server.js)</span>
        <button class="code-block__copy">Copy</button>
      </div>
      <pre><code>const express = require('express');
const app = express();

// ❌ VULNERABLE: Cookie without HttpOnly
app.get('/login', (req, res) => {
  res.cookie('session_token', 'user_secret_session_abc123', {
    // HttpOnly: false (DEFAULT — vulnerable!)
    // Secure: false (DEFAULT — vulnerable!)
