  </div>

  <!-- Remediation -->
  <div class="section">
    <div class="section__header">
      <div class="section__number">Section 3.6</div>
      <h2 class="section__title">Complete Remediation Guide</h2>
    </div>

    <div class="info-box info-box--remediation">
      <div class="info-box__title">✅ Cookie Security Checklist</div>
      <div class="info-box__content">
        <ul>
          <li>✅ <strong>Set HttpOnly flag</strong> on all session/authentication cookies</li>
          <li>✅ <strong>Set Secure flag</strong> to prevent transmission over HTTP</li>
          <li>✅ <strong>Set SameSite=Strict or Lax</strong> to prevent CSRF</li>
          <li>✅ <strong>Use HTTPS everywhere</strong> — force with HSTS header</li>
          <li>✅ <strong>Sanitize all user input</strong> to prevent XSS (use DOMPurify, helmet)</li>
          <li>✅ <strong>Set Content-Security-Policy</strong> header to prevent inline scripts</li>
          <li>✅ <strong>Rotate session IDs</strong> after login and privilege escalation</li>
          <li>✅ <strong>Use short expiration times</strong> — 30 min for sensitive sessions</li>
          <li>✅ <strong>Bind sessions</strong> to user fingerprint (IP + User-Agent hash)</li>
          <li>✅ <strong>Implement cookie prefixes</strong>: <code>__Host-</code> or <code>__Secure-</code></li>
        </ul>
      </div>
    </div>

    <div class="code-block">
      <div class="code-block__header">
        <span class="code-block__lang">JavaScript — Secure Cookie Configuration</span>
        <button class="code-block__copy">Copy</button>
      </div>
      <pre><code>// ✅ SECURE: Properly configured session cookie
res.cookie('__Host-session_id', sessionId, {
  httpOnly: true,     // 🛡️ No JavaScript access
  secure: true,       // 🛡️ HTTPS only
  sameSite: 'strict', // 🛡️ No cross-site sending
  maxAge: 1800000,    // 30 minutes
  path: '/',
  domain: undefined   // __Host- prefix requires no Domain
});

// ✅ SECURE: Express session with helmet
const helmet = require('helmet');
const session = require('express-session');

app.use(helmet());  // Sets CSP, HSTS, X-Frame-Options, etc.
app.use(session({
  secret: crypto.randomBytes(32).toString('hex'),
  resave: false,
  saveUninitialized: false,
  cookie: { httpOnly: true, secure: true, sameSite: 'strict', maxAge: 1800000 }
}));</code></pre>
    </div>
  </div>

