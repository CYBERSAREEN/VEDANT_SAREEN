});

// ❌ VULNERABLE: Reflected XSS in search
app.get('/search', (req, res) => {
  const query = req.query.q;
  // Directly injecting user input into HTML — XSS!
  res.send(`&lt;h1&gt;Results for: ${query}&lt;/h1&gt;`);
